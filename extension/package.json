{
  "name": "php-cdata-code-blocks",
  "displayName": "PHP in XML Code CDATA",
  "description": "Syntax highlighting for PHP inside XML CDATA blocks.",
  "version": "0.9.0",
  "publisher": "hueck-folien",
  "license": "MIT",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "keywords": ["xml", "php", "cdata", "syntax highlighting"],
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "grammars": [
      {
        "scopeName": "source.php-cdata-code.xml",
        "path": "./syntaxes/php-cdata-code.tmLanguage.json",
        "injectTo": ["text.xml"],
        "embeddedLanguages": { "source.php": "php" }
      }
    ]
  }
}
