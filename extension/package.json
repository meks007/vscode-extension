{
  "name": "php-cdata-code-blocks",
  "displayName": "PHP in XML Code CDATA",
  "description": "Syntax highlighting for PHP inside XML CDATA blocks, plus a Smart Outline with follow-cursor for any file that has symbols.",
  "version": "0.8.0",
  "publisher": "hueck-folien",
  "license": "MIT",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "keywords": ["xml", "php", "cdata", "syntax highlighting", "outline"],
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "grammars": [
      {
        "scopeName": "source.php-cdata-code.xml",
        "path": "./syntaxes/php-cdata-code.tmLanguage.json",
        "injectTo": ["text.xml"],
        "embeddedLanguages": { "source.php": "php" }
      }
    ],
    "views": {
      "secondary-sidebar": [
        {
          "id": "phpSmartOutline",
          "name": "Smart Outline"
        }
      ]
    },
    "commands": [
      {
        "command": "phpSmartOutline.refresh",
        "title": "Smart Outline: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "phpSmartOutline.focus",
        "title": "Smart Outline: Focus"
      },
      {
        "command": "phpSmartOutline.dumpSymbols",
        "title": "Smart Outline: Dump Symbol Tree (Debug)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "phpSmartOutline.refresh",
          "when": "view == phpSmartOutline",
          "group": "navigation"
        }
      ]
    }
  }
}
